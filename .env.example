# 环境变量配置模板
# 复制此文件为 .env 并填写实际的配置值

# Tushare配置
# 获取token: https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here

# 数据源配置
DATA_PRIMARY_PROVIDER=tushare
DATA_STORAGE_FORMAT=hdf5

# 因子配置
FACTOR_PARALLEL=true
FACTOR_N_WORKERS=-1

# 回测配置
BACKTEST_INITIAL_CAPITAL=1000000.0
BACKTEST_COMMISSION_RATE=0.0003
BACKTEST_SLIPPAGE_RATE=0.0001

# 日志配置
LOG_LEVEL=INFO
